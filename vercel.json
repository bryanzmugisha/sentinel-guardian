{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "functions": {
    "api/server.js": {
      "includeFiles": "dist/server/**"
    },
    "api/ingest.cjs": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/ingest", "destination": "/api/ingest.cjs" },
    { "source": "/(.*)", "destination": "/api/server" }
  ]
}
